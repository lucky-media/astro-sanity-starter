# Sanity project config — copy to .env and fill in your values
PUBLIC_SANITY_PROJECT_ID=your-project-id
PUBLIC_SANITY_DATASET=production

# Draft / staging mode (set to "true" for SSR draft previews)
PUBLIC_SANITY_USE_DRAFTS=false
PUBLIC_SANITY_VISUAL_EDITING=false
PUBLIC_SANITY_STUDIO_URL=http://localhost:3333

# Required only in draft mode
SANITY_API_TOKEN=
