---
import "@/styles/global.css";
import { resolveMetadata } from "virtual:@lucky-media/astro-seo";
import SEO from "@lucky-media/astro-seo/SEO.astro";
import type { Metadata } from "virtual:@lucky-media/astro-seo";
import { getNavigation } from "@/lib/api";
import { VisualEditing } from "@sanity/astro/visual-editing";

interface Props {
  metadata?: Metadata;
}

const { metadata } = Astro.props;

const navigation = await getNavigation();

const resolved = resolveMetadata(metadata);

const visualEditingEnabled =
  import.meta.env.PUBLIC_SANITY_VISUAL_EDITING === "true";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SEO metadata={resolved} />
  </head>
  <body>
    <slot />

    <VisualEditing enabled={visualEditingEnabled} />
  </body>
</html>
